<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
        https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults public="false" autowire="true" autoconfigure="true" />

        <!-- Services -->
        <service id="JjaDev\QuoteInvoiceBundle\Service\" resource="../src/Service/*" />
        
        <!-- Controllers -->
        <service id="JjaDev\QuoteInvoiceBundle\Controller\" resource="../src/Controller/*" />
        
        <!-- Repositories -->
        <service id="JjaDev\QuoteInvoiceBundle\Repository\" resource="../src/Repository/*" />

        <!-- Form Types -->
        <service id="JjaDev\QuoteInvoiceBundle\Form\" resource="../src/Form/*" />

    </services>
</container>