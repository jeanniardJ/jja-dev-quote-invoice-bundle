{
    "name": "jeanniard/jja-dev-quote-invoice-bundle",
    "version": "0.1.0",
    "description": "Symfony bundle for comprehensive quote and invoice management",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "JJA DEV",
            "email": "contact@jja-dev.fr"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.4|^7.0",
        "symfony/form": "^6.4|^7.0",
        "symfony/validator": "^6.4|^7.0",
        "symfony/twig-bundle": "^6.4|^7.0",
        "symfony/security-bundle": "^6.4|^7.0",
        "symfony/mailer": "^6.4|^7.0",
        "doctrine/orm": "^2.15|^3.0",
        "doctrine/doctrine-bundle": "^2.10",
        "doctrine/doctrine-migrations-bundle": "^3.2",
        "knplabs/knp-paginator-bundle": "^6.0",
        "dompdf/dompdf": "^2.0",
        "symfony/mime": "^6.4|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/test-pack": "^1.0",
        "symfony/browser-kit": "^6.4|^7.0",
        "symfony/css-selector": "^6.4|^7.0",
        "symfony/phpunit-bridge": "^6.4|^7.0"
    },
    "autoload": {
        "psr-4": {
            "JjaDev\\QuoteInvoiceBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JjaDev\\QuoteInvoiceBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "6.4.*",
            "bundle": true
        }
    }
}